import 'package:flutter/material.dart';
import 'package:flutter_riverpod/flutter_riverpod.dart';
import '../../providers/canvas_provider.dart';
import '../../providers/tool_provider.dart';
import '../../../data/models/canvas_object_model.dart';

class QuestionWidgetOverlay extends ConsumerStatefulWidget {
  final CanvasObjectModel object;
  const QuestionWidgetOverlay({super.key, required this.object});

  @override
  ConsumerState<QuestionWidgetOverlay> createState() =>
      _QuestionWidgetOverlayState();
}

class _QuestionWidgetOverlayState extends ConsumerState<QuestionWidgetOverlay> {
  // Local interaction state for 60fps performance
  late double _tempX;
  late double _tempY;
  late double _tempW;
  late double _tempH;
  bool _isInteracting = false;
  bool _isEditing = false;
  
  // Edit controllers
  late TextEditingController _questionCtrl;
  late List<TextEditingController> _optionCtrls;

  @override
  void initState() {
    super.initState();
    _tempX = widget.object.x;
    _tempY = widget.object.y;
    _tempW = widget.object.width;
    _tempH = widget.object.height;
    _questionCtrl = TextEditingController();
    _optionCtrls = [];
  }

  @override
  void didUpdateWidget(QuestionWidgetOverlay oldWidget) {
    super.didUpdateWidget(oldWidget);
    if (!_isInteracting) {
      _tempX = widget.object.x;
      _tempY = widget.object.y;
      _tempW = widget.object.width;
      _tempH = widget.object.height;
    }
  }

  @override
  void dispose() {
    _questionCtrl.dispose();
    for (final c in _optionCtrls) {
      c.dispose();
    }
    super.dispose();
  }

  void _syncControllers(Question q) {
    _questionCtrl.text = q.questionText;
    final options = q.options;
    while (_optionCtrls.length < options.length) {
      _optionCtrls.add(TextEditingController());
    }
    for (int i = 0; i < options.length; i++) {
      _optionCtrls[i].text = options[i].text;
    }
  }

  void _commitInteraction() {
    setState(() => _isInteracting = false);
    ref.read(canvasStateProvider.notifier).updateObject(
      widget.object.copyWith(
        x: _tempX,
        y: _tempY,
        width: _tempW,
        height: _tempH,
      ),
    );
  }

  void _commitEdit() {
    final q = widget.object.data as Question;
    final updatedOptions = q.options.asMap().entries.map((e) {
      final i = e.key;
      final opt = e.value;
      final newText = i < _optionCtrls.length ? _optionCtrls[i].text : opt.text;
      return QuestionOption(id: opt.id, label: opt.label, text: newText, imageUrl: opt.imageUrl);
    }).toList();

    final updatedQuestion = Question(
      id: q.id,
      questionNumber: q.questionNumber,
      questionText: _questionCtrl.text,
      questionImage: q.questionImage,
      options: updatedOptions,
      correctAnswer: q.correctAnswer,
      examSource: q.examSource,
      subject: q.subject,
    );
    
    ref.read(canvasStateProvider.notifier).updateObject(
      widget.object.copyWith(data: updatedQuestion),
    );
    setState(() => _isEditing = false);
  }

  @override
  Widget build(BuildContext context) {
    final toolState = ref.watch(toolProvider);
    final isSelectTool = toolState.activeTool == Tool.select || toolState.activeTool == Tool.selectObject;
    final obj = widget.object;
    final q = obj.data as Question;

    return Positioned(
      left: _tempX,
      top: _tempY,
      child: RepaintBoundary(
        child: GestureDetector(
          onTap: () {
            if (isSelectTool) {
              ref.read(canvasStateProvider.notifier).selectObject(obj.id);
            }
          },
          onDoubleTap: () {
            if (isSelectTool && !obj.isLocked) {
               _syncControllers(q);
               setState(() => _isEditing = true);
            }
          },
          onPanStart: (isSelectTool && !obj.isLocked && !_isEditing) 
              ? (_) => setState(() => _isInteracting = true) 
              : null,
          onPanUpdate: (isSelectTool && !obj.isLocked && !_isEditing)
              ? (d) {
                  setState(() {
                    _tempX = (_tempX + d.delta.dx).clamp(0.0, 1920.0 - _tempW);
                    _tempY = (_tempY + d.delta.dy).clamp(0.0, 1080.0 - _tempH);
                  });
                }
              : null,
          onPanEnd: (isSelectTool && !obj.isLocked && !_isEditing)
              ? (_) => _commitInteraction()
              : null,
          child: SizedBox(
            width: _tempW,
            height: _tempH,
            child: Stack(
              clipBehavior: Clip.none,
              children: [
                // ── Card body ──────────────────────────────────────────────────
                _CardContent(
                  object: obj,
                  isEditing: _isEditing,
                  questionCtrl: _questionCtrl,
                  optionCtrls: _optionCtrls,
                  onToggleLock: () => ref.read(canvasStateProvider.notifier).updateObject(
                    obj.copyWith(isLocked: !obj.isLocked)
                  ),
                  onCommitEdit: _isEditing ? _commitEdit : null,
                  onDelete: () => ref.read(canvasStateProvider.notifier).removeObject(obj.id),
                ),

                // ── Selection Decoration (border + handles) ─────────────────────
                if (obj.isSelected) ...[
                  IgnorePointer(
                    child: Container(
                      decoration: BoxDecoration(
                        border: Border.all(color: const Color(0xFFFF6B35), width: 2),
                        borderRadius: BorderRadius.circular(obj.style.borderRadius),
                      ),
                    ),
                  ),
                  if (!obj.isLocked) ...[
                     _CornerHandle(
                       alignment: Alignment.topLeft,
                       onDrag: (dx, dy) => _resize(dx, dy, left: true, top: true),
                       onEnd: _commitInteraction,
                     ),
                     _CornerHandle(
                       alignment: Alignment.topRight,
                       onDrag: (dx, dy) => _resize(dx, dy, right: true, top: true),
                       onEnd: _commitInteraction,
                     ),
                     _CornerHandle(
                       alignment: Alignment.bottomLeft,
                       onDrag: (dx, dy) => _resize(dx, dy, left: true, bottom: true),
                       onEnd: _commitInteraction,
                     ),
                     _CornerHandle(
                       alignment: Alignment.bottomRight,
                       onDrag: (dx, dy) => _resize(dx, dy, right: true, bottom: true),
                       onEnd: _commitInteraction,
                     ),
                  ],
                ],
              ],
            ),
          ),
        ),
      ),
    );
  }

  void _resize(double dx, double dy, {bool left = false, bool right = false, bool top = false, bool bottom = false}) {
    setState(() {
      _isInteracting = true;
      if (left) {
        final newW = (_tempW - dx).clamp(300.0, 1800.0);
        _tempX -= (newW - _tempW);
        _tempW = newW;
      }
      if (right) {
        _tempW = (_tempW + dx).clamp(300.0, 1800.0);
      }
      if (top) {
        final newH = (_tempH - dy).clamp(200.0, 1000.0);
        _tempY -= (newH - _tempH);
        _tempH = newH;
      }
      if (bottom) {
        _tempH = (_tempH + dy).clamp(200.0, 1000.0);
      }
    });
  }
}

class _CardContent extends StatelessWidget {
  final CanvasObjectModel object;
  final bool isEditing;
  final TextEditingController questionCtrl;
  final List<TextEditingController> optionCtrls;
  final VoidCallback onToggleLock;
  final VoidCallback? onCommitEdit;
  final VoidCallback onDelete;

  const _CardContent({
    required this.object,
    required this.isEditing,
    required this.questionCtrl,
    required this.optionCtrls,
    required this.onToggleLock,
    required this.onCommitEdit,
    required this.onDelete,
  });

  @override
  Widget build(BuildContext context) {
    final style = object.style;
    final q = object.data as Question;

    return Container(
      decoration: BoxDecoration(
        color: Color(style.questionBgColor),
        borderRadius: BorderRadius.circular(style.borderRadius),
        boxShadow: [
          BoxShadow(
            color: Colors.black.withOpacity(object.isSelected ? 0.5 : 0.2),
            blurRadius: object.isSelected ? 20 : 10,
          ),
        ],
      ),
      child: ClipRRect(
        borderRadius: BorderRadius.circular(style.borderRadius),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.stretch,
          children: [
            _HeaderBar(
              isLocked: object.isLocked,
              isEditing: isEditing,
              onToggleLock: onToggleLock,
              onCommitEdit: onCommitEdit,
              onDelete: onDelete,
            ),
            Expanded(
              child: Padding(
                padding: EdgeInsets.all(style.padding),
                child: isEditing
                    ? _EditForm(q: q, style: style, qCtrl: questionCtrl, oCtrls: optionCtrls)
                    : _ViewContent(q: q, style: style),
              ),
            ),
          ],
        ),
      ),
    );
  }
}

class _HeaderBar extends StatelessWidget {
  final bool isLocked;
  final bool isEditing;
  final VoidCallback onToggleLock;
  final VoidCallback? onCommitEdit;
  final VoidCallback onDelete;
  const _HeaderBar({required this.isLocked, required this.isEditing, required this.onToggleLock, required this.onCommitEdit, required this.onDelete});

  @override
  Widget build(BuildContext context) {
    return Container(
      height: 32, color: Colors.white10,
      child: Row(
        children: [
          const SizedBox(width: 8),
          const Icon(Icons.drag_indicator, size: 14, color: Colors.white24),
          const Spacer(),
          if (isEditing) 
            IconButton(icon: const Icon(Icons.check, size: 14, color: Colors.green), onPressed: onCommitEdit, padding: EdgeInsets.zero, constraints: const BoxConstraints()),
          IconButton(icon: Icon(isLocked ? Icons.lock : Icons.lock_open, size: 14, color: isLocked ? Colors.orange : Colors.white24), onPressed: onToggleLock, padding: EdgeInsets.zero, constraints: const BoxConstraints()),
          IconButton(icon: const Icon(Icons.delete_outline, size: 14, color: Colors.white24), onPressed: onDelete, padding: EdgeInsets.zero, constraints: const BoxConstraints()),
          const SizedBox(width: 4),
        ],
      ),
    );
  }
}

class _ViewContent extends StatelessWidget {
  final Question q;
  final QuestionStyle style;
  const _ViewContent({required this.q, required this.style});
  @override
  Widget build(BuildContext context) {
    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: [
        Text(q.questionText, style: TextStyle(color: Color(style.questionTextColor), fontSize: style.fontSize, fontWeight: FontWeight.bold)),
        const SizedBox(height: 12),
        ...q.options.asMap().entries.map((e) => Padding(
          padding: const EdgeInsets.only(bottom: 6),
          child: Row(
            children: [
              CircleAvatar(radius: 10, child: Text(e.value.label.isEmpty ? String.fromCharCode(65+e.key) : e.value.label, style: const TextStyle(fontSize: 10))),
              const SizedBox(width: 8),
              Text(e.value.text, style: TextStyle(color: Color(style.optionTextColor), fontSize: style.fontSize * 0.8)),
            ],
          ),
        )),
      ],
    );
  }
}

class _EditForm extends StatelessWidget {
  final Question q;
  final QuestionStyle style;
  final TextEditingController qCtrl;
  final List<TextEditingController> oCtrls;
  const _EditForm({required this.q, required this.style, required this.qCtrl, required this.oCtrls});
  @override
  Widget build(BuildContext context) {
    return SingleChildScrollView(child: Column(children: [
      TextField(controller: qCtrl, maxLines: 2, style: const TextStyle(color: Colors.white, fontSize: 14), decoration: const InputDecoration(labelText: 'Question')),
      const SizedBox(height: 10),
      ...List.generate(q.options.length, (i) => TextField(
        controller: i < oCtrls.length ? oCtrls[i] : null,
        style: const TextStyle(color: Colors.white, fontSize: 12),
        decoration: InputDecoration(labelText: 'Option ${String.fromCharCode(65+i)}'),
      )),
    ]));
  }
}

class _CornerHandle extends StatelessWidget {
  final Alignment alignment;
  final Function(double dx, double dy) onDrag;
  final VoidCallback onEnd;
  const _CornerHandle({required this.alignment, required this.onDrag, required this.onEnd});
  @override
  Widget build(BuildContext context) {
    return Align(alignment: alignment, child: GestureDetector(
      onPanUpdate: (d) => onDrag(d.delta.dx, d.delta.dy),
      onPanEnd: (_) => onEnd(),
      child: Container(width: 14, height: 14, decoration: BoxDecoration(color: Colors.white, shape: BoxShape.circle, border: Border.all(color: const Color(0xFFFF6B35), width: 2))),
    ));
  }
}
