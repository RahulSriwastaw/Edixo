generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model WhiteboardAccount {
  id        String   @id @default(uuid())
  loginId   String   @unique
  password  String
  name      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("whiteboard_accounts")
}

model WhiteboardSession {
  id        String   @id @default(uuid())
  sessionId String   @unique
  teacherId String?
  setId     String?
  data      Json
  savedAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogAuthor {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  bio       String?
  photoUrl  String?
  email     String?
  isActive  Boolean   @default(true)
  postCount Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  posts     BlogPost[]

  @@map("blog_authors")
}

model BlogCategory {
  id        String     @id @default(uuid())
  name      String
  slug      String     @unique
  description String?
  color     String?
  icon      String?
  sortOrder Int        @default(0)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  posts     BlogPostCategory[]

  @@map("blog_categories")
}

model BlogTag {
  id        String  @id @default(uuid())
  name      String
  slug      String  @unique
  createdAt DateTime @default(now())

  posts     BlogPostTag[]

  @@map("blog_tags")
}

model BlogPost {
  id                 String          @id @default(uuid())
  title              String
  slug               String          @unique
  content            String?
  contentHtml        String?
  contentText        String?
  excerpt            String?
  featuredImageUrl   String?
  featuredImageAlt   String?

  contentType        String          @default("blog")
  status             String          @default("draft")
  visibility         String          @default("public")
  password           String?

  platform           String          @default("both")  // "public_website", "mokebook", "both"

  authorId           String
  author             BlogAuthor      @relation(fields: [authorId], references: [id])

  categories         BlogPostCategory[]
  tags               BlogPostTag[]
  revisions          BlogRevision[]

  seoTitle           String?
  seoDescription     String?
  focusKeyword       String?
  secondaryKeywords  String?
  canonicalUrl       String?
  robotsIndex        Boolean         @default(true)
  robotsFollow       Boolean         @default(true)
  schemaType         String          @default("BlogPosting")

  ogTitle            String?
  ogDescription      String?
  ogImageUrl         String?
  twitterCard        String          @default("summary_large_image")

  allowComments      Boolean         @default(true)
  isFeatured         Boolean         @default(false)
  isPinned           Boolean         @default(false)

  wordCount          Int             @default(0)
  readingTimeMin     Int             @default(1)
  viewCount          Int             @default(0)
  likeCount          Int             @default(0)
  shareCount         Int             @default(0)

  publishedAt        DateTime?
  scheduledAt        DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([status, platform])
  @@index([slug])
  @@index([authorId])
  @@index([publishedAt])
  @@map("blog_posts")
}

model BlogPostCategory {
  postId     String
  categoryId String

  post       BlogPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category   BlogCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([postId, categoryId])
  @@map("blog_post_categories")
}

model BlogPostTag {
  postId String
  tagId  String

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("blog_post_tags")
}

model BlogRevision {
  id        String   @id @default(uuid())
  postId    String
  title     String?
  content   String?
  revisedBy String
  createdAt DateTime @default(now())

  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("blog_revisions")
}

model PlatformAuditLog {
  id        String   @id @default(uuid())
  actorId   String
  actorType String
  actorName String
  action    String
  resource  String?
  changes   Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("platform_audit_logs")
}

model airtable_sync_folders {
  id              String   @id
  name            String
  slug            String   @unique
  total_questions Int      @default(0)
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @db.Timestamptz(6)
}

model airtable_sync_metadata {
  table_name      String    @id
  total_questions Int       @default(0)
  last_sync_at    DateTime? @db.Timestamptz(6)
  status          String    @default("NOT_SYNCED")
  error           String?
}

model question_options {
  id          String    @id
  question_id String
  text_en     String?
  text_hi     String?
  is_correct  Boolean   @default(false)
  sort_order  Int       @default(0)
  questions   questions @relation(fields: [question_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model question_set_items {
  set_id        String
  question_id   String
  sort_order    Int           @default(0)
  questions     questions     @relation(fields: [question_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  question_sets question_sets @relation(fields: [set_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([set_id, question_id])
}

model question_sets {
  id                 String               @id
  set_id             String               @unique
  pin                String
  name               String
  description        String?
  total_questions    Int                  @default(0)
  subject            String?
  chapter            String?
  is_global          Boolean              @default(false)
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  updated_at         DateTime             @default(now()) @db.Timestamptz(6)
  pdf_notes          Json?
  visual_settings    Json?
  folderId           String?
  mockTestSections   MockTestSection[]
  question_set_items question_set_items[]
  folder             qBankFolder?         @relation("QuestionSetFolder", fields: [folderId], references: [id])
}

model questions {
  id                  String               @id
  question_id         String               @unique
  text_en             String
  text_hi             String?
  type                String               @default("mcq")
  difficulty          String               @default("medium")
  subject_name        String?
  chapter_name        String?
  point_cost          Int                  @default(5)
  usage_count         Int                  @default(0)
  is_approved         Boolean              @default(false)
  is_global           Boolean              @default(false)
  created_at          DateTime             @default(now()) @db.Timestamptz(6)
  updated_at          DateTime             @default(now()) @updatedAt @db.Timestamptz(6)
  question_no         Int?
  explanation_en      String?
  explanation_hi      String?
  exam                String?
  collection          String?
  year                Int?
  date                DateTime?            @db.Timestamptz(6)
  section             String?
  airtable_table_name String?
  record_id           String?
  folderId            String?
  attemptAnswers      AttemptAnswer[]
  question_options    question_options[]
  question_set_items  question_set_items[]
  folder              qBankFolder?         @relation("QuestionFolder", fields: [folderId], references: [id])
}

model ai_settings {
  id                String   @id @default("singleton")
  defaultTextModel  String   @default("OPENROUTER_GEMMA_4_26B")
  defaultImageModel String   @default("GEMINI_1_5_FLASH")
  top5Models        Json     @default("[\"GEMINI_1_5_FLASH\", \"OPENROUTER_GEMMA_4_26B\", \"MODAL_GLM_5_1\"]")
  apiKeyGemini      String?
  apiKeyOpenRouter  String?
  apiKeyModal       String?
  apiKeyClaude      String?
  updatedAt         DateTime @updatedAt
}

model qBankFolder {
  id          String          @id @default(uuid())
  name        String          @db.VarChar(255)
  slug        String          @db.VarChar(255)
  path        String          @default("/")
  depth       Int             @default(0)
  scope       String          @default("GLOBAL")
  parentId    String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  description String?
  color       String?
  icon        String?
  sortOrder   Int             @default(0)
  parent      qBankFolder?    @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children    qBankFolder[]   @relation("FolderHierarchy")
  sets        question_sets[] @relation("QuestionSetFolder")
  questions   questions[]     @relation("QuestionFolder")

  @@index([parentId])
  @@map("qbank_folders")
}

model ExamFolder {
  id               String         @id @default(uuid())
  name             String
  slug             String?        @unique
  description      String?
  icon             String?
  color            String?
  isFeatured       Boolean        @default(false)
  sortOrder        Int            @default(0)
  interfaceThemeId String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  categories       ExamCategory[]
  interfaceTheme   ExamInterfaceTheme? @relation(fields: [interfaceThemeId], references: [id])

  @@map("exam_folders")
}

model ExamCategory {
  id               String            @id @default(uuid())
  folderId         String
  name             String
  slug             String?           @unique
  description      String?
  icon             String?
  isFeatured       Boolean           @default(false)
  isFree           Boolean           @default(true)
  price            Float?
  discountPrice    Float?
  sortOrder        Int               @default(0)
  interfaceThemeId String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  folder           ExamFolder        @relation(fields: [folderId], references: [id], onDelete: Cascade)
  subCategories    ExamSubCategory[]
  interfaceTheme   ExamInterfaceTheme? @relation(fields: [interfaceThemeId], references: [id])

  @@map("exam_categories")
}

model ExamSubCategory {
  id          String       @id @default(uuid())
  categoryId  String
  parentId    String?
  name        String
  description String?
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  category    ExamCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  mockTests   MockTest[]

  @@map("exam_subcategories")
}

model ExamInterfaceTheme {
  id              String         @id @default(uuid())
  name            String
  description     String?
  layoutVariant   String         @default("default")
  config          Json           @default("{}")
  screenshotUrl   String?
  isDefault       Boolean        @default(false)
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  mockTests       MockTest[]
  categories      ExamCategory[]
  folders         ExamFolder[]

  @@map("exam_interface_themes")
}

model MockTest {
  id               String            @id @default(uuid())
  testId           String            @unique
  pin              String
  name             String
  description      String?
  status           String            @default("DRAFT")
  durationMins     Int
  totalMarks       Float             @default(0)
  passingMarks     Float?
  shuffleQuestions Boolean           @default(false)
  showResult       Boolean           @default(true)
  maxAttempts      Int               @default(1)
  isPublic         Boolean           @default(false)
  scheduledAt      DateTime?
  endsAt           DateTime?
  subCategoryId    String?
  interfaceThemeId String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  batches          MockTestBatch[]
  sections         MockTestSection[]
  subCategory      ExamSubCategory?  @relation(fields: [subCategoryId], references: [id])
  interfaceTheme   ExamInterfaceTheme? @relation(fields: [interfaceThemeId], references: [id])
  attempts         TestAttempt[]

  @@map("mock_tests")
}

model MockTestSection {
  id           String        @id @default(uuid())
  testId       String
  setId        String
  name         String
  sortOrder    Int           @default(0)
  durationMins Int?
  set          question_sets @relation(fields: [setId], references: [id], map: "fk_mockTestSection_set")
  test         MockTest      @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@map("mock_test_sections")
}

model MockTestBatch {
  id      String   @id @default(uuid())
  testId  String
  batchId String
  test    MockTest @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@unique([testId, batchId])
  @@map("mock_test_batches")
}

model Student {
  id            String                    @id @default(uuid())
  studentId     String                    @unique @default(uuid())
  userId        String                    @unique
  name          String
  email         String?
  mobile        String?
  isActive      Boolean                   @default(true)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  targetExamId  String?
  subscriptions StudentSubscription[]
  attempts      TestAttempt[]
  enrollments   StudentSeriesEnrollment[]

  @@map("students")
}

model TestAttempt {
  id            String          @id @default(uuid())
  testId        String
  studentId     String
  status        String          @default("IN_PROGRESS")
  startedAt     DateTime        @default(now())
  submittedAt   DateTime?
  score         Float?
  totalMarks    Float?
  rank          Int?
  percentile    Float?
  timeTakenSecs Int?
  createdAt     DateTime        @default(now())
  answers       AttemptAnswer[]
  student       Student         @relation(fields: [studentId], references: [id])
  test          MockTest        @relation(fields: [testId], references: [id])

  @@map("test_attempts")
}

model AttemptAnswer {
  id              String      @id @default(uuid())
  attemptId       String
  questionId      String
  selectedOptions String[]    @default([])
  isCorrect       Boolean?
  marksAwarded    Float?
  timeTakenSecs   Int?
  attempt         TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questions       questions   @relation(fields: [questionId], references: [id])

  @@map("attempt_answers")
}

model User {
  id           String    @id @default(uuid())
  email        String?   @unique
  mobile       String?   @unique
  passwordHash String
  role         String    @default("STUDENT")
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("users")
}

model MockbookPlan {
  id              String                @id @default(uuid())
  name            String
  slug            String                @unique
  description     String?
  price           Float
  discountPrice   Float?
  durationDays    Int
  features        Json                  @default("[]")
  accessType      String                @default("GLOBAL")
  examCategoryIds String[]              @default([])
  isActive        Boolean               @default(true)
  sortOrder       Int                   @default(0)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  subscriptions   StudentSubscription[]

  @@map("mockbook_plans")
}

model StudentSubscription {
  id            String       @id @default(uuid())
  studentId     String
  planId        String
  startDate     DateTime     @default(now())
  endDate       DateTime
  status        String       @default("ACTIVE")
  amountPaid    Float
  paymentId     String?
  paymentMethod String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  plan          MockbookPlan @relation(fields: [planId], references: [id])
  student       Student      @relation(fields: [studentId], references: [id])

  @@map("student_subscriptions")
}

model StudentSeriesEnrollment {
  id           String       @id @default(uuid())
  studentId    String
  seriesId     String
  enrolledAt   DateTime     @default(now())
  status       String       @default("ACTIVE")
  student      Student      @relation(fields: [studentId], references: [id])

  @@unique([studentId, seriesId])
  @@map("student_series_enrollments")
}

// ─── SARKARI RESULT MODELS ─────────────────────────────────────

model SarkariCategory {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  type        String    @default("job") // "job", "result", "admit_card", "answer_key", "admission", "syllabus", "previous_paper", "current_affairs", "scholarship", "document"
  icon        String?
  color       String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  posts SarkariPost[]

  @@map("sarkari_categories")
}

model SarkariTag {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  posts SarkariPostTag[]

  @@map("sarkari_tags")
}

model SarkariPost {
  id              String          @id @default(uuid())
  title           String
  slug            String          @unique
  content         String?
  excerpt         String?

  // Post Type
  postType        String          @default("job") // "job", "result", "admit_card", "answer_key", "admission", "syllabus", "previous_paper", "current_affairs", "scholarship", "document"
  status          String          @default("draft") // "draft", "published", "scheduled"
  isFeatured      Boolean         @default(false)
  isPinned        Boolean         @default(false)
  viewCount       Int             @default(0)

  // Media
  featuredImageUrl  String?
  featuredImageAlt  String?

  // Dates
  lastUpdatedDate DateTime?
  applicationStartDate DateTime?
  applicationEndDate   DateTime?
  examDate         DateTime?
  resultDate       DateTime?
  admitCardDate    DateTime?
  objectionLastDate DateTime?
  releaseDate      DateTime?

  // Organization / University
  organization    String?
  university      String?
  courseName      String?

  // Important Fields
  totalPosts      Int?
  applicationFee  Json?           // JSON string of fee structure
  ageLimit        Json?           // JSON string of age limit details
  vacancyDetails  Json?           // JSON string of vacancy table
  eligibility     Json?           // JSON string of eligibility criteria
  selectionProcess Json?          // JSON string of selection process
  howToApply      String?
  importantLinks  Json?           // JSON array of {title, url} objects
  faqData         Json?           // JSON array of {question, answer} objects
  importantDates  Json?           // JSON array of {event, date} objects

  // State / Central
  jobType         String?         // "central", "state", "public_sector"
  stateName       String?         // For state-level jobs

  // Qualifications
  qualification   String?         // "10th", "12th", "graduate", "diploma", "iti", "engineering", "any"

  // SEO
  seoTitle        String?
  seoDescription  String?
  focusKeyword    String?
  canonicalUrl    String?
  robotsIndex     Boolean         @default(true)
  robotsFollow    Boolean         @default(true)
  schemaType      String          @default("NewsArticle")

  // Category & Tags
  categoryId      String?
  category        SarkariCategory? @relation(fields: [categoryId], references: [id])
  tags            SarkariPostTag[]

  // Timestamps
  publishedAt     DateTime?
  scheduledAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([postType, status])
  @@index([slug])
  @@index([categoryId])
  @@index([publishedAt])
  @@map("sarkari_posts")
}

model SarkariPostTag {
  postId String
  tagId  String

  post SarkariPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  SarkariTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("sarkari_post_tags")
}
