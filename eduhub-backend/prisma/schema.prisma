generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SuperAdmin {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  fullName      String
  role          String   @default("OWNER")
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("super_admins")
}

model Organization {
  id                 String   @id @default(uuid())
  orgCode            String   @unique
  orgName            String
  slug               String   @unique
  legalName          String?
  logoUrl            String?
  websiteUrl         String?
  contactEmail       String?
  contactPhone       String?
  addressLine1       String?
  city               String?
  state              String?
  country            String?
  pinCode            String?
  status             String   @default("ACTIVE")
  isWhiteLabel       Boolean  @default(false)
  subscriptionPlan   String?
  subscriptionStatus String?
  trialEndsAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("organizations")
}

model AiCreditTransaction {
  id            String   @id @default(uuid())
  organizationId String?
  amount        Int
  type          String
  reference     String?
  createdAt     DateTime @default(now())

  @@map("ai_credit_transactions")
}

model OrgFeatureFlag {
  id             String   @id @default(uuid())
  organizationId String
  key            String
  value          Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, key])
  @@map("org_feature_flags")
}

model OrgAuditLog {
  id             String   @id @default(uuid())
  organizationId String
  actorId        String?
  action         String
  entityType     String?
  entityId       String?
  metadata       Json?
  createdAt      DateTime @default(now())

  @@map("org_audit_logs")
}

model OrgImpersonationLog {
  id             String   @id @default(uuid())
  organizationId String
  superAdminId   String
  startedAt      DateTime @default(now())
  endedAt        DateTime?

  @@map("org_impersonation_logs")
}

model UserPurchasedPack {
  id        String   @id @default(uuid())
  userId    String
  packId    String
  createdAt DateTime @default(now())

  @@map("user_purchased_packs")
}

model UserQuestion {
  id         String   @id @default(uuid())
  userId     String
  questionId String
  createdAt  DateTime @default(now())

  @@map("user_questions")
}

model BlogAuthor {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  bio         String?
  photoUrl    String?    @map("photo_url")
  email       String?    @unique
  designation String?
  socialLinks Json?      @map("social_links")
  isActive    Boolean    @default(true) @map("is_active")
  postCount   Int        @default(0) @map("post_count")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  posts       BlogPost[]

  @@map("blog_authors")
}

model BlogCategory {
  id          String         @id @default(uuid())
  name        String
  slug        String         @unique
  description String?
  parentId    String?        @map("parent_id")
  parent      BlogCategory?  @relation("BlogCategoryToChildren", fields: [parentId], references: [id])
  children    BlogCategory[] @relation("BlogCategoryToChildren")
  isActive    Boolean        @default(true) @map("is_active")
  sortOrder   Int            @default(0) @map("sort_order")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  posts       BlogPost[]

  @@map("blog_categories")
}

model BlogTag {
  id        String        @id @default(uuid())
  name      String
  slug      String        @unique
  createdAt DateTime      @default(now()) @map("created_at")
  posts     BlogPostTag[]

  @@map("blog_tags")
}

model BlogPost {
  id                 String         @id @default(uuid())
  title              String
  slug               String         @unique
  contentHtml        String?        @map("content_html")
  contentText        String?        @map("content_text")
  excerpt            String?
  status             String         @default("draft")
  visibility         String         @default("public")
  password           String?
  featuredImageUrl   String?        @map("featured_image_url")
  featuredImageAlt   String?        @map("featured_image_alt")
  contentType        String         @default("blog") @map("content_type")
  platform           String         @default("public_website")
  seoTitle           String?        @map("seo_title")
  seoDescription     String?        @map("seo_description")
  focusKeyword       String?        @map("focus_keyword")
  secondaryKeywords  Json?          @map("secondary_keywords")
  ogTitle            String?        @map("og_title")
  ogDescription      String?        @map("og_description")
  ogImageUrl         String?        @map("og_image_url")
  canonicalUrl       String?        @map("canonical_url")
  robotsIndex        Boolean        @default(true) @map("robots_index")
  robotsFollow       Boolean        @default(true) @map("robots_follow")
  schemaType         String?        @map("schema_type")
  allowComments      Boolean        @default(true) @map("allow_comments")
  isFeatured         Boolean        @default(false) @map("is_featured")
  publishedAt        DateTime?      @map("published_at")
  scheduledAt        DateTime?      @map("scheduled_at")
  viewCount          Int            @default(0) @map("view_count")
  readingTimeMinutes Int?           @map("reading_time_minutes")
  authorId           String?        @map("author_id")
  author             BlogAuthor?    @relation(fields: [authorId], references: [id])
  categoryId         String?        @map("category_id")
  category           BlogCategory?  @relation(fields: [categoryId], references: [id])
  tags               BlogPostTag[]
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  @@map("blog_posts")
}

model BlogPostTag {
  postId String @map("post_id")
  tagId  String @map("tag_id")
  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("blog_post_tags")
}

model SarkariCategory {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  type        String    @default("job")
  icon        String?
  color       String?
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  posts SarkariPost[]

  @@map("sarkari_categories")
}

model SarkariTag {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  posts SarkariPostTag[]

  @@map("sarkari_tags")
}

model SarkariPost {
  id                   String           @id @default(uuid())
  title                String
  slug                 String           @unique
  content              String?
  excerpt              String?
  postType             String           @default("job") @map("post_type")
  status               String           @default("draft")
  isFeatured           Boolean          @default(false) @map("is_featured")
  isPinned             Boolean          @default(false) @map("is_pinned")
  viewCount            Int              @default(0) @map("view_count")
  featuredImageUrl     String?          @map("featured_image_url")
  featuredImageAlt     String?          @map("featured_image_alt")
  lastUpdatedDate      DateTime?        @map("last_updated_date")
  applicationStartDate DateTime?        @map("application_start_date")
  applicationEndDate   DateTime?        @map("application_end_date")
  examDate             DateTime?        @map("exam_date")
  resultDate           DateTime?        @map("result_date")
  admitCardDate        DateTime?        @map("admit_card_date")
  objectionLastDate    DateTime?        @map("objection_last_date")
  releaseDate          DateTime?        @map("release_date")
  organization         String?
  university           String?
  courseName           String?          @map("course_name")
  totalPosts           Int?             @map("total_posts")
  applicationFee       Json?            @map("application_fee")
  ageLimit             Json?            @map("age_limit")
  vacancyDetails       Json?            @map("vacancy_details")
  eligibility          Json?
  selectionProcess     Json?            @map("selection_process")
  howToApply           String?          @map("how_to_apply")
  importantLinks       Json?            @map("important_links")
  faqData              Json?            @map("faq_data")
  importantDates       Json?            @map("important_dates")
  jobType              String?          @map("job_type")
  stateName            String?          @map("state_name")
  qualification        String?
  seoTitle             String?          @map("seo_title")
  seoDescription       String?          @map("seo_description")
  focusKeyword         String?          @map("focus_keyword")
  canonicalUrl         String?          @map("canonical_url")
  robotsIndex          Boolean          @default(true) @map("robots_index")
  robotsFollow         Boolean          @default(true) @map("robots_follow")
  schemaType           String           @default("NewsArticle") @map("schema_type")
  categoryId           String?          @map("category_id")
  category             SarkariCategory? @relation(fields: [categoryId], references: [id])
  tags                 SarkariPostTag[]
  publishedAt          DateTime?        @map("published_at")
  scheduledAt          DateTime?        @map("scheduled_at")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")

  @@index([postType, status])
  @@index([slug])
  @@index([categoryId])
  @@index([publishedAt])
  @@map("sarkari_posts")
}

model SarkariPostTag {
  postId String @map("post_id")
  tagId  String @map("tag_id")

  post SarkariPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  SarkariTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("sarkari_post_tags")
}
