generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model WhiteboardAccount {
  id                  String                  @id @default(uuid())
  loginId             String                  @unique
  password            String
  name                String?
  isActive            Boolean                 @default(true)
  maxConcurrentLogins Int                     @default(1)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  loginSessions       WhiteboardLoginSession[]

  @@map("whiteboard_accounts")
}

model WhiteboardLoginSession {
  id        String             @id @default(uuid())
  accountId String
  tokenId   String             @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  account   WhiteboardAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, revokedAt, expiresAt])
  @@map("whiteboard_login_sessions")
}

model WhiteboardSession {
  id        String   @id @default(uuid())
  sessionId String   @unique
  teacherId String?
  setId     String?
  data      Json
  savedAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlatformAuditLog {
  id        String   @id @default(uuid())
  actorId   String
  actorType String
  actorName String
  action    String
  resource  String?
  changes   Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("platform_audit_logs")
}