{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "lib": [
            "ES2022"
        ],
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "paths": {
            "@/*": [
                "./src/*"
            ]
        }
    },
    "include": [
        "src/server.ts",
        "src/config/**/*",
        "src/middleware/**/*",
        "src/modules/auth/**/*",
        "src/modules/superAdmin/**/*",
        "src/modules/mockbook/**/*",
        "src/modules/tests/**/*",
        "src/modules/qbank/**/*",
        "src/modules/ai/**/*",
        "src/modules/whiteboard/**/*",
        "src/modules/whiteboardAccount/**/*",
        "src/modules/students/**/*",
        "src/modules/organizations/**/*",
        "src/modules/upload/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}